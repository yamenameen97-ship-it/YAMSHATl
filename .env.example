# ============================================================
# YAMSHAT - متغيرات البيئة (نسخة مثال)
# ============================================================
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية
# لا ترفع .env إلى Git مطلقاً

# --- قاعدة البيانات ---
DATABASE_URL=postgresql://user:password@localhost:5432/yamshat
REDIS_URL=redis://localhost:6379/0

# --- الأمان ---
SECRET_KEY=ضع-قيمة-سرية-قوية-هنا-32-حرف-على-الأقل
JWT_SECRET_KEY=ضع-قيمة-JWT-سرية-قوية-هنا
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ORIGIN_REGEX=^https://.*\.onrender\.com$

# --- روابط الخدمات (للـ Gateway) ---
AUTH_SERVICE_URL=http://localhost:8001
USER_SERVICE_URL=http://localhost:8002
POST_SERVICE_URL=http://localhost:8003
CHAT_SERVICE_URL=http://localhost:8004
NOTIFICATION_SERVICE_URL=http://localhost:8005
MEDIA_SERVICE_URL=http://localhost:8006
SEARCH_SERVICE_URL=http://localhost:8007
BILLING_SERVICE_URL=http://localhost:8008
IDENTITY_SERVICE_URL=http://localhost:8009

# --- التخزين السحابي (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- البريد (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=noreply@yamshat.com

# --- LiveKit للمكالمات المرئية ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Firebase Cloud Messaging ---
FIREBASE_CREDENTIALS_JSON=

# --- وضع التشغيل ---
DEBUG=false
CAPTCHA_ENABLED=true

# YAMSHAT backend test env
# Local test setup - replace missing values later before production

PROJECT_NAME=YAMSHAT API
SERVICE_NAME=yamshat-backend
ENVIRONMENT=development
DEBUG=true

# Local test database
DATABASE_URL=sqlite:///./yamshat.db

# IMPORTANT: replace before production
SECRET_KEY=temporary-local-test-secret-change-me
ALGORITHM=HS256

# Local origins for testing
FRONTEND_ORIGIN=http://localhost:5173
BACKEND_ORIGIN=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# Realtime / sockets
REDIS_URL=

# Firebase push notifications
PUSH_PROVIDER=firebase
FIREBASE_CREDENTIALS_PATH=backend/firebase/service-account.json

# LiveKit (URL available, API credentials still needed)
LIVEKIT_URL=wss://yamshat-enqr8c2d.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional media CDN - leave empty for local upload fallback
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Optional social login
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_REDIRECT_URI=

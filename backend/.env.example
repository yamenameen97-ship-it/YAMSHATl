# ==============================
# YAMSHAT Backend - Render Example
# انسخ هذا الملف إلى backend/.env وعدّل القيم
# ==============================

ENVIRONMENT=production
DEBUG=false
PROJECT_NAME=YAMSHAT API
SERVICE_NAME=yamshat-backend

# Core
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
SESSION_REFRESH_EXPIRE_HOURS=12
DB_BOOTSTRAP_ON_START=true
DB_STATEMENT_TIMEOUT_MS=8000

# Origins / CORS
FRONTEND_ORIGIN=https://your-frontend.onrender.com
BACKEND_ORIGIN=https://your-api.onrender.com
RENDER_EXTERNAL_URL=https://your-api.onrender.com
CORS_ORIGINS=https://your-frontend.onrender.com,https://your-api.onrender.com
CORS_ORIGIN_REGEX=^https://[a-z0-9-]+(?:-\d+)?\.onrender\.com$

# Redis
REDIS_URL=redis://default:PASSWORD@HOST:6379
REDIS_PREFIX=yamshat

# Cookies / Session security
REFRESH_COOKIE_NAME=yamshat_refresh_token
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_SECURE=true
COOKIE_SAMESITE=none
HSTS_MAX_AGE_SECONDS=31536000

# Auth hardening
LOGIN_RATE_LIMIT_PER_MINUTE=10
REGISTER_RATE_LIMIT_PER_MINUTE=10
API_RATE_LIMIT_PER_MINUTE=100
REFRESH_RATE_LIMIT_PER_MINUTE=20
REFRESH_MIN_INTERVAL_SECONDS=2
VERIFY_RATE_LIMIT_PER_MINUTE=12
RESEND_RATE_LIMIT_PER_MINUTE=6
CAPTCHA_ENABLED=true
CAPTCHA_RATE_LIMIT_PER_MINUTE=20
CAPTCHA_EXPIRE_MINUTES=5
BRUTE_FORCE_MAX_ATTEMPTS=8
BRUTE_FORCE_LOCKOUT_SECONDS=300

# Email / verification
EMAIL_VERIFICATION_CODE_EXPIRE_MINUTES=15
PASSWORD_RESET_CODE_EXPIRE_MINUTES=15
RESEND_API_KEY=
RESEND_FROM=
RESEND_REPLY_TO=
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USERNAME=resend
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
EMAIL_ADDRESS=
EMAIL_PASSWORD=

# Primary admin / demo accounts
PRIMARY_ADMIN_EMAIL=admin@example.com
PRIMARY_ADMIN_PASSWORD=ChangeMe123!
DEMO_ACCOUNT_EMAIL=demo@example.com
DEMO_ACCOUNT_PASSWORD=ChangeMe123!

# OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-api.onrender.com/api/auth/oauth/google/callback
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_REDIRECT_URI=https://your-api.onrender.com/api/auth/oauth/facebook/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_OAUTH_REDIRECT_URI=https://your-api.onrender.com/api/auth/oauth/apple/callback

# Phone / SMS
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
AWS_REGION=us-east-1
PHONE_VERIFICATION_CODE_EXPIRE_MINUTES=10
PHONE_VERIFICATION_MAX_ATTEMPTS=5
PHONE_VERIFICATION_LOCKOUT_MINUTES=15

# Push / Firebase
PUSH_PROVIDER=firebase
FIREBASE_CREDENTIALS_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=
GOOGLE_APPLICATION_CREDENTIALS=

# Media / uploads
ALLOWED_UPLOAD_EXTENSIONS=png,jpg,jpeg,webp,gif,mp4,webm,mov
RESUMABLE_UPLOAD_MAX_SIZE_MB=512
UPLOAD_SCAN_STRATEGY=best-effort
EXTERNAL_SCAN_URL=
EXTERNAL_SCAN_API_KEY=
CDN_BASE_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=yamshat
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_FOLDER=yamshat

# Live / calls
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional observability
ENABLE_METRICS=true
ENABLE_TRACING=false
JAEGER_AGENT_HOST=
JAEGER_AGENT_PORT=6831
CRASH_REPORTING_DSN=
FRONTEND_CRASH_REPORTING_DSN=
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER=custom-endpoint
ANALYTICS_FORWARD_URL=
ANALYTICS_SHARED_SECRET=

# Optional extra hardening
ADMIN_MFA_ENABLED=false
ADMIN_MFA_TOTP_SECRET=
ADMIN_ALLOWED_IPS=
THREAT_MONITOR_WINDOW_SECONDS=60
THREAT_UNIQUE_PATH_THRESHOLD=20
BOT_SCORE_BLOCK_THRESHOLD=80
DDOS_BURST_LIMIT_PER_10_SECONDS=80
DDOS_BLOCK_SECONDS=180
SOCKET_MESSAGE_MIN_INTERVAL_SECONDS=1.0
SOCKET_EVENT_BURST_LIMIT=20
SOCKET_EVENT_WINDOW_SECONDS=10
SOCKET_TYPING_MIN_INTERVAL_SECONDS=0.4
SOCKET_REPLAY_WINDOW_SECONDS=30
SOCKET_NONCE_TTL_SECONDS=120
SOCKET_PERMISSION_REVALIDATION_SECONDS=45
SOCKET_ABUSE_BLOCK_SECONDS=300
SOCKET_DUPLICATE_WINDOW_SECONDS=20
SPAM_SCORE_BLOCK_THRESHOLD=65

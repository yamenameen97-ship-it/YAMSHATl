# ضع القيم الحقيقية داخل Render Dashboard ولا ترفع الأسرار داخل Git
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql://username:password@host:5432/database_name

FRONTEND_ORIGIN=https://yamshatl-1.onrender.com
BACKEND_ORIGIN=https://yamshatl.onrender.com
RENDER_EXTERNAL_URL=https://yamshatl.onrender.com
ALLOWED_ORIGINS=https://yamshatl-1.onrender.com,https://yamshatl.onrender.com,capacitor://localhost,ionic://localhost,http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:5000,http://localhost:5000


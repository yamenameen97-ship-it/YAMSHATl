# =====================================================
# YAMSHAT Frontend Environment Example
# انسخ هذا الملف باسم .env وعدّل القيم الحساسة
# =====================================================

# --- API Configuration ---
VITE_API_URL=http://localhost:8000
VITE_API_BASE=http://localhost:8000/api
VITE_BACKEND_ORIGIN=http://localhost:8000
VITE_SOCKET_URL=http://localhost:8000
VITE_WS_HOST=localhost:8000

# --- App Metadata ---
VITE_APP_VERSION=1.0.0
VITE_LOG_LEVEL=info
VITE_ENABLE_FRONTEND_LOGGING=true
VITE_ENABLE_PERFORMANCE_METRICS=false
VITE_PRIMARY_ADMIN_EMAIL=admin@example.com

# --- Realtime / WebSocket Feature Flags ---
VITE_DISABLE_REALTIME_WS=false
VITE_ENABLE_CHAT_CACHE=true
VITE_ENABLE_OFFLINE_QUEUE=true
VITE_ENABLE_DEV_LOGIN=true
VITE_SIGNAL_SERVER_SUPPORT=true

# --- TURN / STUN Servers ---
VITE_STUN_URL=stun:stun.l.google.com:19302
VITE_STUN_URL_FALLBACK=stun:stun1.l.google.com:19302
VITE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
VITE_TURN_URL=
VITE_TURN_URL_FALLBACK=
VITE_TURN_URL_TCP=
VITE_TURN_URLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# --- LiveKit ---
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# --- Cloudinary / CDN ---
VITE_CDN_BASE=
VITE_CLOUDINARY_URL=https://api.cloudinary.com/v1_1/YOUR_CLOUD/image/upload
VITE_CLOUDINARY_PRESET=your_preset

# --- Media Upload Configuration ---
VITE_MEDIA_PROVIDER=cloudinary
VITE_MEDIA_UPLOAD_URL=/api/media/upload
VITE_MEDIA_MAX_SIZE=52428800
VITE_MEDIA_ALLOWED_TYPES=image/jpeg,image/png,image/webp,image/gif,video/mp4,video/webm
VITE_MEDIA_SIGNED_URLS=true
VITE_MEDIA_SIGNED_URL_ENDPOINT=/api/media/signed-url
VITE_MEDIA_EXPIRING_LINKS=true
VITE_SIGNED_URL_TTL_SECONDS=3600
VITE_MEDIA_ENCRYPT_UPLOADS=false
VITE_MEDIA_KEY_ID=default
VITE_UPLOAD_CONCURRENCY=3

# --- Resumable Uploads ---
VITE_MEDIA_RESUMABLE_THRESHOLD=10485760
VITE_MEDIA_RESUMABLE_START_URL=/api/media/resumable/start
VITE_MEDIA_RESUMABLE_CHUNK_URL=/api/media/resumable/chunk
VITE_MEDIA_RESUMABLE_COMPLETE_URL=/api/media/resumable/complete
VITE_MEDIA_RESUMABLE_STATUS_URL=/api/media/resumable/status

# --- Image / Video Optimization ---
VITE_IMAGE_MAX_DIMENSION=1920
VITE_IMAGE_MAX_SIZE_MB=10
VITE_IMAGE_QUALITY=0.85
VITE_VIDEO_CHUNK_SIZE=5242880
VITE_VIDEO_QUALITIES=360p,480p,720p,1080p
VITE_VIDEO_THUMBNAIL_COUNT=3

# --- Web Push ---
VITE_VAPID_PUBLIC_KEY=

# --- Firebase ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Security / Feature Flags ---
VITE_ENABLE_E2E_ENCRYPTION=true
VITE_BRUTE_FORCE_MAX_ATTEMPTS=5
VITE_ENABLE_IMAGE_OPTIMIZATION=true
VITE_ENABLE_ANALYTICS=false

/**
 * مثال على كيفية دمج مدير Service Worker في main.jsx
 * 
 * انسخ هذا الكود إلى ملف main.jsx الحالي
 */

import React from 'react';
import ReactDOM from 'react-dom/client';
import { QueryClient, QueryClientProvider } from '@tanstack/react-query';
import { HashRouter } from 'react-router-dom';

// استيراد المكونات الأساسية
import App from './App';
import { RealtimeProvider } from './contexts/RealtimeContext';
import { AppStoreProvider } from './stores/AppStore';

// ✅ استيراد مدير Service Worker الجديد
import { registerServiceWorker } from './service-worker-manager';

// استيراد الأنماط العامة
import './index.css';

// إنشاء عميل Query
const queryClient = new QueryClient({
  defaultOptions: {
    queries: {
      staleTime: 1000 * 60 * 5, // 5 دقائق
      gcTime: 1000 * 60 * 10, // 10 دقائق
    },
  },
});

// ✅ دالة لتهيئة التطبيق والخدمات
async function initializeApp() {
  // تسجيل Service Worker المحسّن
  const swRegistration = await registerServiceWorker();
  
  if (swRegistration) {
    console.log('✅ تم تسجيل Service Worker بنجاح');
  } else {
    console.warn('⚠️ فشل تسجيل Service Worker');
  }

  // ✅ الاستماع لأحداث التحديث
  window.addEventListener('yamshat:update-available', (event) => {
    console.log('📢 تحديث جديد متاح:', event.detail.version);
    // يمكنك إضافة منطق إضافي هنا
  });

  // ✅ الاستماع لأحداث المزامنة
  window.addEventListener('yamshat:sync-now', (event) => {
    console.log('🔄 طلب مزامنة من Service Worker');
    // يمكنك إضافة منطق المزامنة هنا
  });
}

// ✅ تهيئة التطبيق عند التحميل
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initializeApp);
} else {
  initializeApp();
}

// تحسينات الأداء
if (window.performance && window.performance.mark) {
  window.performance.mark('app-render-start');
}

// معالج الأخطاء العام
window.addEventListener('error', (event) => {
  console.error('❌ خطأ غير متوقع:', event.error);
});

window.addEventListener('unhandledrejection', (event) => {
  console.error('❌ Promise رفضت بدون معالج:', event.reason);
});

// تصيير التطبيق
const root = ReactDOM.createRoot(document.getElementById('root'));

root.render(
  <React.StrictMode>
    <QueryClientProvider client={queryClient}>
      <AppStoreProvider>
        <HashRouter>
          <RealtimeProvider>
            <App />
          </RealtimeProvider>
        </HashRouter>
      </AppStoreProvider>
    </QueryClientProvider>
  </React.StrictMode>
);

// تسجيل نقطة نهاية الأداء
if (window.performance && window.performance.mark) {
  window.performance.mark('app-render-end');
  window.performance.measure(
    'app-render',
    'app-render-start',
    'app-render-end'
  );
  
  const measure = window.performance.getEntriesByName('app-render')[0];
  console.log(`⏱️ وقت تصيير التطبيق: ${measure.duration.toFixed(2)}ms`);
}

// تصدير دوال مفيدة للاستخدام من خارج المكون
export { registerServiceWorker };

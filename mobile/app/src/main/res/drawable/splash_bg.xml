<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/splash_gradient_start"
                android:centerColor="@color/splash_gradient_center"
                android:endColor="@color/splash_gradient_end" />
        </shape>
    </item>
    <item android:top="-220dp" android:right="-120dp">
        <shape android:shape="oval">
            <solid android:color="@color/splash_accent_primary" />
            <size android:width="420dp" android:height="420dp" />
        </shape>
    </item>
    <item android:top="380dp" android:left="-140dp">
        <shape android:shape="oval">
            <solid android:color="@color/splash_accent_secondary" />
            <size android:width="360dp" android:height="360dp" />
        </shape>
    </item>
</layer-list>

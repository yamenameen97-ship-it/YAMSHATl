<?xml version='1.0' encoding='utf-8'?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/background" android:orientation="vertical" android:padding="12dp">

    <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="22dp" app:cardElevation="0dp" app:strokeColor="@color/divider" app:strokeWidth="1dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:padding="14dp">

            <TextView android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/btn_primary" android:gravity="center" android:text="💬" android:textSize="18sp" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">

                <TextView android:id="@+id/chatTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الدردشة" android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold" />

                <TextView android:id="@+id/statusText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="جاري التحميل..." android:textColor="@color/text_secondary" android:textSize="13sp" />
            </LinearLayout>

            <ImageButton android:id="@+id/e2eBtn" android:layout_width="42dp" android:layout_height="42dp" android:background="@drawable/bg_icon_button" android:contentDescription="E2E" android:src="@drawable/ic_ui_lock" android:tint="@color/text_primary" style="@style/Widget.App.IconButton" android:scaleType="centerInside" />

            <ImageButton android:id="@+id/audioCallBtn" android:layout_width="42dp" android:layout_height="42dp" android:layout_marginStart="8dp" android:background="@drawable/bg_icon_button" android:contentDescription="Audio Call" android:src="@drawable/ic_ui_call" android:tint="@color/text_primary" style="@style/Widget.App.IconButton" android:scaleType="centerInside" />

            <ImageButton android:id="@+id/videoCallBtn" android:layout_width="42dp" android:layout_height="42dp" android:layout_marginStart="8dp" android:background="@drawable/bg_icon_button" android:contentDescription="Video Call" android:src="@drawable/ic_ui_videocam" android:tint="@color/text_primary" style="@style/Widget.App.IconButton" android:scaleType="centerInside" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView android:id="@+id/typingText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:paddingStart="6dp" android:textColor="@color/text_secondary" android:textSize="12sp" />

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/chatRecycler" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:clipToPadding="false" android:paddingBottom="6dp" />

    <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="24dp" app:cardElevation="0dp" app:strokeColor="@color/divider" app:strokeWidth="1dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:padding="10dp">

            <ImageButton android:id="@+id/attachBtn" android:layout_width="42dp" android:layout_height="42dp" android:background="@drawable/bg_icon_button" android:contentDescription="Attach" android:src="@drawable/ic_ui_gallery" android:tint="@color/text_primary" style="@style/Widget.App.IconButton" android:scaleType="centerInside" />

            <ImageButton android:id="@+id/voiceBtn" android:layout_width="42dp" android:layout_height="42dp" android:layout_marginStart="8dp" android:background="@drawable/bg_icon_button" android:contentDescription="Voice" android:src="@drawable/ic_ui_mic" android:tint="@color/text_primary" style="@style/Widget.App.IconButton" android:scaleType="centerInside" />

            <EditText android:id="@+id/msgInput" android:layout_width="0dp" android:layout_height="48dp" android:layout_marginStart="8dp" android:layout_weight="1" android:background="@drawable/bg_input" android:hint="اكتب رسالة..." android:paddingHorizontal="14dp" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" style="@style/Widget.App.InputField" />

            <Button android:id="@+id/sendBtn" android:layout_width="wrap_content" android:layout_height="48dp" android:layout_marginStart="8dp" android:text="إرسال" style="@style/Widget.App.Button" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="30dp"
            android:paddingBottom="24dp">

            <FrameLayout
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:background="@drawable/btn_primary"
                android:padding="18dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:contentDescription="Yamshat Official Logo"
                    android:src="@drawable/yam_logo" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="YAMSHAT"
                android:textColor="@color/text_primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="استرجاع كلمة المرور"
                android:textColor="@color/text_primary"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="ابعت رمز التحقق، وبعدها لو الرمز صحيح هيفتح فورم تغيير كلمة المرور فوراً"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <EditText
                    android:id="@+id/emailInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="البريد الإلكتروني"
                    android:importantForAutofill="yes"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary" />

                <Button
                    android:id="@+id/sendCodeBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="إرسال رمز التحقق" />

                <TextView
                    android:id="@+id/devCodeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:alpha="0"
                    android:textColor="@color/primary_soft"
                    android:textSize="13sp" />

                <LinearLayout
                    android:id="@+id/verificationSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="رمز التحقق"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="المربعات تقرأ الرمز تلقائياً عند اللصق أو القراءة من الحافظة"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <EditText android:id="@+id/codeDigit1" android:layout_width="44dp" android:layout_height="52dp" android:layout_margin="4dp" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/text_primary" />
                        <EditText android:id="@+id/codeDigit2" android:layout_width="44dp" android:layout_height="52dp" android:layout_margin="4dp" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/text_primary" />
                        <EditText android:id="@+id/codeDigit3" android:layout_width="44dp" android:layout_height="52dp" android:layout_margin="4dp" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/text_primary" />
                        <EditText android:id="@+id/codeDigit4" android:layout_width="44dp" android:layout_height="52dp" android:layout_margin="4dp" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/text_primary" />
                        <EditText android:id="@+id/codeDigit5" android:layout_width="44dp" android:layout_height="52dp" android:layout_margin="4dp" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/text_primary" />
                        <EditText android:id="@+id/codeDigit6" android:layout_width="44dp" android:layout_height="52dp" android:layout_margin="4dp" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/readClipboardBtn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="قراءة الرمز من الحافظة" />

                    <Button
                        android:id="@+id/verifyCodeBtn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="تأكيد الرمز" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/resetSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="كلمة المرور الجديدة"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/newPasswordInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="كلمة المرور الجديدة"
                        android:importantForAutofill="yes"
                        android:inputType="textPassword"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />

                    <EditText
                        android:id="@+id/confirmPasswordInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="تأكيد كلمة المرور"
                        android:inputType="textPassword"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />

                    <Button
                        android:id="@+id/savePasswordBtn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="حفظ كلمة المرور الجديدة" />
                </LinearLayout>

                <Button
                    android:id="@+id/backToLoginBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="العودة لتسجيل الدخول" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>

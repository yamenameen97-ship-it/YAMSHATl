<?xml version='1.0' encoding='utf-8'?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingTop="4dp" android:paddingBottom="4dp">

    <LinearLayout android:id="@+id/bubbleRoot" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_marginEnd="8dp" android:background="@drawable/msg_received" android:elevation="1dp" android:orientation="vertical" android:padding="12dp">

        <TextView android:id="@+id/text1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxWidth="280dp" android:textColor="@color/text_primary" android:textSize="15sp" />

        <ImageView android:id="@+id/mediaPreview" android:layout_width="220dp" android:layout_height="220dp" android:layout_marginTop="8dp" android:adjustViewBounds="true" android:background="@drawable/bg_card" android:scaleType="centerCrop" android:visibility="gone" />

        <Button android:id="@+id/actionBtn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="فتح الوسائط" android:visibility="gone" style="@style/Widget.App.Button" />

        <TextView android:id="@+id/metaText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/text_secondary" android:textSize="11sp" />
    </LinearLayout>
</FrameLayout>
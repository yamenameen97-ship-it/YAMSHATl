<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <VideoView
        android:id="@+id/videoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_scrim" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="bottom"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="استمتع بمحتوى قصير سريع وسحب رأسي سلس"
                android:textColor="#E6FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- أزرار التفاعل (على الجهة اليمنى = نهاية السطر في RTL) -->
        <LinearLayout
            android:id="@+id/reactionsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/likeButton"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_input"
                android:gravity="center"
                android:text="❤"
                android:textColor="@color/text_primary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/likeCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="12.8K"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!--
        ========================================================
        الزر العائم لسحب الريل (Drag Handle / Floating Drag Button)
        تم نقله من الجهة اليمنى (حيث أزرار التفاعل ❤) إلى الجهة
        اليسرى (start في RTL) حتى لا يغطّي أزرار التفاعل.
        ========================================================
    -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/dragReelFab"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="120dp"
        android:contentDescription="سحب الريل"
        android:src="@android:drawable/ic_menu_sort_by_size"
        app:backgroundTint="#66000000"
        app:fabSize="mini"
        app:tint="@color/text_primary"
        xmlns:app="http://schemas.android.com/apk/res-auto" />
</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.App.Card.Surface" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">@dimen/radius_xl</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">@dimen/stroke_hairline</item>
    </style>

    <style name="Widget.App.Card.LegacySurface" parent="CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">@dimen/radius_xl</item>
        <item name="cardElevation">0dp</item>
        <item name="cardUseCompatPadding">false</item>
    </style>

    <style name="Widget.App.IconButton" parent="Widget.AppCompat.ImageButton">
        <item name="android:background">@drawable/bg_icon_button</item>
        <item name="android:tint">@color/text_primary</item>
        <item name="android:padding">@dimen/icon_button_padding</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:minWidth">@dimen/control_height_sm</item>
        <item name="android:minHeight">@dimen/control_height_sm</item>
    </style>

    <style name="Widget.App.InputField" parent="Widget.App.EditText">
        <item name="android:minHeight">@dimen/control_height_md</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Widget.App.InputField.Otp" parent="Widget.App.InputField">
        <item name="android:background">@drawable/bg_input_otp</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">1</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.App.Progress.Circular" parent="@android:style/Widget.ProgressBar">
        <item name="android:indeterminateTint">@color/primary</item>
        <item name="android:indeterminateTintMode">src_in</item>
    </style>

    <style name="Widget.App.EmptyState">
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingLeft">@dimen/dialog_padding</item>
        <item name="android:paddingTop">@dimen/dialog_padding</item>
        <item name="android:paddingRight">@dimen/dialog_padding</item>
        <item name="android:paddingBottom">@dimen/dialog_padding</item>
    </style>

    <style name="Widget.App.EmptyState.Icon">
        <item name="android:layout_width">@dimen/empty_state_icon</item>
        <item name="android:layout_height">@dimen/empty_state_icon</item>
        <item name="android:tint">@color/text_secondary</item>
    </style>

    <style name="Widget.App.EmptyState.Title">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.App.EmptyState.Body">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="ThemeOverlay.App.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/surface</item>
        <item name="android:colorBackground">@color/surface</item>
        <item name="backgroundTint">@color/surface</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.App.Dialog.Body</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.App.Dialog.Title</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.App.Dialog</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.App.Dialog.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.App.Dialog.Button.Secondary</item>
    </style>

    <style name="ShapeAppearance.App.Dialog" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_xl</item>
    </style>

    <style name="TextAppearance.App.Dialog.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.App.Dialog.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Widget.App.Dialog.Button" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/primary_soft</item>
        <item name="textAllCaps">false</item>
    </style>

    <style name="Widget.App.Dialog.Button.Secondary" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="textAllCaps">false</item>
    </style>
</resources>

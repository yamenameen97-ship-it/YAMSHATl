<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.App" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/primary_soft</item>
        <item name="colorOnSecondary">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="android:windowBackground">@drawable/splash_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="buttonStyle">@style/Widget.App.Button</item>
        <item name="editTextStyle">@style/Widget.App.InputField</item>
        <item name="imageButtonStyle">@style/Widget.App.IconButton</item>
        <item name="cardViewStyle">@style/Widget.App.Card.LegacySurface</item>
        <item name="bottomNavigationStyle">@style/Widget.App.BottomNavigation</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.App.Dialog</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.App.Dialog</item>
    </style>

    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/btn_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="textAllCaps">false</item>
        <item name="android:minHeight">@dimen/control_height_lg</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">@dimen/radius_lg</item>
        <item name="android:elevation">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.App.QuickActionButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">@dimen/stroke_hairline</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="backgroundTint">@color/card_alt</item>
        <item name="android:minHeight">@dimen/control_height_sm</item>
        <item name="textAllCaps">false</item>
        <item name="android:elevation">0dp</item>
        <item name="android:paddingLeft">@dimen/space_md</item>
        <item name="android:paddingRight">@dimen/space_md</item>
    </style>

    <style name="Widget.App.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:paddingLeft">@dimen/input_padding_horizontal</item>
        <item name="android:paddingRight">@dimen/input_padding_horizontal</item>
        <item name="android:paddingTop">@dimen/input_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/input_padding_vertical</item>
    </style>

    <style name="Widget.App.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView.Colored">
        <item name="itemIconTint">@color/bottom_nav_colors</item>
        <item name="itemTextColor">@color/bottom_nav_colors</item>
        <item name="itemRippleColor">@color/primary</item>
        <item name="android:background">@drawable/bg_card</item>
        <item name="elevation">0dp</item>
    </style>
</resources>

# انسخ هذا الملف إلى backend/.env أو إلى متغيرات Render الخاصة بخدمة الباك إند
# مهم: DATABASE_URL هنا يجب أن يكون رابط PostgreSQL الداخلي Internal Database URL من Render
# الصحيح: لصق الرابط كما هو من صفحة قاعدة البيانات في Render > Connections > Internal Database URL
# يقبل التطبيق أيضاً صيغة postgres:// وسيحوّلها داخلياً إلى postgresql:// تلقائياً
# الخطأ: وضع Placeholder مثل USER/PASSWORD/HOST/DATABASE أو وضعه في الفرونت إند أو في تطبيق الموبايل

PROJECT_NAME=YAMSHAT API
SERVICE_NAME=yamshat-backend
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# مثال داخلي تقريبي من Render:
# DATABASE_URL=postgresql://yamshat_user:strong_password@dpg-xxxxxxxxxxxx-a:5432/yamshat_db
# مثال خارجي تقريبي إذا احتجته خارج Render فقط:
# DATABASE_URL=postgresql://yamshat_user:strong_password@dpg-xxxxxxxxxxxx-a.oregon-postgres.render.com/yamshat_db?sslmode=require
REDIS_URL=

# روابط النشر
FRONTEND_ORIGIN=https://your-frontend.onrender.com
BACKEND_ORIGIN=https://your-backend.onrender.com
RENDER_EXTERNAL_URL=https://your-backend.onrender.com
CORS_ORIGINS=https://your-frontend.onrender.com,https://your-backend.onrender.com
CORS_ORIGIN_REGEX=^https://[a-z0-9-]+(?:-\d+)?\.onrender\.com$

# الحسابات المطلوبة
PRIMARY_ADMIN_EMAIL=yamenameen97@gmail.com
PRIMARY_ADMIN_PASSWORD=yamen1234
DEMO_ACCOUNT_EMAIL=yasryameen21@gmail.com
DEMO_ACCOUNT_PASSWORD=12345678

# الجلسات والكوكيز
REFRESH_COOKIE_NAME=yamshat_refresh_token
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_SECURE=true
COOKIE_SAMESITE=none

# إعدادات النظام
DB_BOOTSTRAP_ON_START=false
CAPTCHA_ENABLED=true
ANALYTICS_ENABLED=true
ADMIN_MFA_ENABLED=false

# البريد - اختياري
RESEND_API_KEY=
RESEND_FROM=
RESEND_REPLY_TO=
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USERNAME=resend
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# خدمات اختيارية
FIREBASE_SERVICE_ACCOUNT_JSON=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_FOLDER=/yamshat
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# انسخ هذا الملف إلى frontend/.env.production أثناء البناء أو ضع نفس القيم في Render لخدمة الفرونت إند
# مهم: لا تضع DATABASE_URL هنا نهائياً
# لو الفرونت والباك على نفس الدومين/الخدمة يمكنك ترك VITE_API_BASE و VITE_BACKEND_ORIGIN فارغين
# لو النشر split services اكتب روابط الباك إند الصريحة

VITE_API_BASE=
VITE_BACKEND_ORIGIN=
VITE_SOCKET_URL=
VITE_CDN_BASE=
VITE_PRIMARY_ADMIN_EMAIL=yamenameen97@gmail.com
VITE_ENABLE_DEV_LOGIN=false
VITE_ENABLE_OFFLINE_QUEUE=true
VITE_ENABLE_CHAT_CACHE=true
VITE_ENABLE_FRONTEND_LOGGING=true
VITE_ENABLE_PERFORMANCE_METRICS=true
